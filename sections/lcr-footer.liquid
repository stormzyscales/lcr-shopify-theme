{% comment %} sections/lcr-footer.liquid {% endcomment %}

<style>
  .lcr-footer {
    background: var(--c-off-white);
    border-top: 1px solid var(--c-silver);
    padding: 4rem 0 2rem;
  }
  .lcr-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--c-silver);
    margin-bottom: 2rem;
  }
  .lcr-footer__brand-name {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 400;
    color: var(--c-dark);
    display: block;
    margin-bottom: 0.75rem;
  }
  .lcr-footer__brand-desc {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--c-mid);
    line-height: 1.7;
    max-width: 28ch;
    margin-bottom: 1.5rem;
  }
  .lcr-footer__col-title {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-dark);
    margin-bottom: 1.1rem;
    display: block;
  }
  .lcr-footer__links { display: flex; flex-direction: column; gap: 0.6rem; }
  .lcr-footer__links a {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--c-mid);
    transition: color 0.2s;
  }
  .lcr-footer__links a:hover { color: var(--c-dark); }

  .lcr-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .lcr-footer__copy { font-size: 0.72rem; font-weight: 300; color: var(--c-mid); }
  .lcr-footer__legal { display: flex; gap: 1.5rem; }
  .lcr-footer__legal a { font-size: 0.72rem; font-weight: 300; color: var(--c-mid); transition: color 0.2s; }
  .lcr-footer__legal a:hover { color: var(--c-dark); }

  @media (max-width: 900px) { .lcr-footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .lcr-footer__grid { grid-template-columns: 1fr; } }
</style>

<footer class="lcr-footer" role="contentinfo">
  <div class="lcr-container">
    <div class="lcr-footer__grid">
      <div>
        <span class="lcr-footer__brand-name">LCR</span>
        <p class="lcr-footer__brand-desc">Luxury Car Rentals — Cape Town, South Africa. Curated vehicles, concierge service, unforgettable drives.</p>
      </div>
      <div>
        <span class="lcr-footer__col-title">Fleet</span>
        <nav class="lcr-footer__links">
          <a href="/collections/sports">Sports Cars</a>
          <a href="/collections/suv">Luxury SUV</a>
          <a href="/collections/convertible">Convertibles</a>
          <a href="/collections/saloon">Saloons</a>
        </nav>
      </div>
      <div>
        <span class="lcr-footer__col-title">Company</span>
        <nav class="lcr-footer__links">
          <a href="/pages/about">About</a>
          <a href="/pages/experiences">Experiences</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/contact">Contact</a>
        </nav>
      </div>
      <div>
        <span class="lcr-footer__col-title">Contact</span>
        <nav class="lcr-footer__links">
          <a href="tel:+27000000000">+27 (0)00 000 0000</a>
          <a href="mailto:hello@lcr.co.za">hello@lcr.co.za</a>
          <a href="/pages/enquire">Enquire Now</a>
        </nav>
      </div>
    </div>
    <div class="lcr-footer__bottom">
      <span class="lcr-footer__copy">&copy; {{ 'now' | date: '%Y' }} LCR Luxury Car Rentals. All rights reserved.</span>
      <div class="lcr-footer__legal">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/policies/refund-policy">Cancellations</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Footer", "settings": [] }
{% endschema %}
